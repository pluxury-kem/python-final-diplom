# Виртуальное окружение (У ВАС ЭТО ПАПКА en/)
en/
venv/
env/
ENV/
env.bak/
venv.bak/
*.env

# База данных
db.sqlite3
db.sqlite3.*
*.db
*.sqlite
*.sqlite3-journal

# Бэкапы базы данных
db.sqlite3.backup_*
*.backup
*.bak

# Медиа и загруженные файлы
media/
/media/
/media/*
!/media/.keep

# Кэш Python
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
*.so

# Миграции (НО нужно оставить файлы миграций в репозитории!)
# Не добавляем это в .gitignore, просто для информации
# migrations/ - НЕ ИГНОРИРУЕМ!

# Тестовые файлы (кроме основных тестов)
test_*.yaml
test_*.yml
!test_price.yaml  # если это эталонный тестовый файл
test_import_simple.py
test_order_creation.py
*.yaml.bak
*.yml.bak

# Временные файлы
*.log
*.tmp
*.temp
*.pid
*.sql
*.pot
*.mo
*.po
*.bak
*~
*.swp
*.swo

# Файлы проекта (которые не нужно коммитить)
project_tree.txt
reset_migrations.sh
example_shop.yaml
test_import_simple.py
test_order_creation.py
*.yaml~
*.py~

# Референсные материалы (если это не часть проекта)
reference/
/reference/*
!/reference/.keep

# Директория с документацией (если это не исходники)
/data/  # если data содержит только тестовые данные
/data/*
!/data/.keep
!/data/shop1.yaml  # если shop1.yaml нужен для демонстрации

# IDE
.idea/
.vscode/
*.sublime-*
.project
.pydevproject
.settings/

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Логи
*.log
logs/
/logs/

# Тестовые отчеты
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.dmypy.json
dmypy.json

# Secrets
.secrets
.secrets/*
.env
*.key
*.pem

